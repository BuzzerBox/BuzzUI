# defaults to "/home/pi/BuzzerBox"
#INSTALL_DIR="/home/pi/BuzzerBox"
# defaults to "BuzzerBoxNetwork"
#WIFI_SSID="BuzzerBoxNetwork"
# defaults to "DE"
#WIFI_COUNTRY_CODE="DE"
# defaults to "12TheBuzzerBox_IncredibleNetwork34"
#WIFI_PASSPHRASE="12TheBuzzerBox_IncredibleNetwork34"
# defaults to "10.0.0.5"
#SERVER_IP_ADDRESS="10.0.0.5"
# Multiple hostnames can be defined by concatenating the hostnames with a ";", see default value. Defaults to "buzzer.box;buzzerbox.local"
#HOSTNAMES="buzzer.box;buzzerbox.local"
# Sets the location that the splash image will be copied to. Defaults to "/home/pi/Pictures/splash.png"
#SPLASH_IMAGE_TARGET_LOCATION="/home/pi/Pictures/splash.png"
# Whether the overlay FS should automatically get enabled by the install procedure. Defaults to "true"
ACTIVATE_OVERLAY_FS=false
