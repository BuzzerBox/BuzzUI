{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "sourceMap": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "outDir": "dist",
    "resolveJsonModule": true
  },
  "lib": ["es2015"],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "include": ["**/*", "../shared/*"]
}
